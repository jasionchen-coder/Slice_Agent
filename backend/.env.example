APP_DATABASE_URL=sqlite:///./data/app.db
# APP_DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
APP_STORAGE_ROOT=./storage
APP_MAX_UPLOAD_MB=2048
APP_AUTO_PROCESS=true
APP_CELERY_BROKER_URL=redis://localhost:6379/0
APP_CELERY_RESULT_BACKEND=redis://localhost:6379/1
APP_AUDIO_CHUNK_SECONDS=600
APP_AUDIO_CHUNK_OVERLAP_SECONDS=2
APP_AUDIO_EXTRACT_RETRIES=1
APP_ASR_RETRIES=2
APP_LLM_RETRIES=2
APP_FFMPEG_CUT_RETRIES=1
APP_DEFAULT_LANGUAGE=zh
APP_REQUEST_TIMEOUT_SECONDS=120
APP_FFMPEG_PATH=ffmpeg
APP_FFPROBE_PATH=ffprobe

# Provider selection.
# Options: mock, groq, ark. OpenAI/Anthropic config is reserved for later.
APP_ASR_PROVIDER=mock
APP_LLM_PROVIDER=mock

# Groq API, for ASR and optional LLM.
APP_GROQ_API_KEY=
APP_GROQ_BASE_URL=https://api.groq.com/openai/v1
APP_GROQ_ASR_MODEL=whisper-large-v3-turbo
APP_GROQ_LLM_MODEL=llama-3.3-70b-versatile

# OpenAI-compatible LLM config.
APP_OPENAI_API_KEY=
APP_OPENAI_BASE_URL=https://api.openai.com/v1
APP_OPENAI_LLM_MODEL=gpt-4.1-mini

# Anthropic/Claude LLM config.
APP_ANTHROPIC_API_KEY=
APP_ANTHROPIC_BASE_URL=https://api.anthropic.com
APP_ANTHROPIC_LLM_MODEL=claude-3-5-sonnet-latest

# Volcano Engine Ark, OpenAI-compatible LLM config.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
